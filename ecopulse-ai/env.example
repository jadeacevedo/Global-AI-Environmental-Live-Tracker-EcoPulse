# EcoPulse AI — Environment Variables
# Copy this file to .env and fill in your tokens.
# All APIs listed here have FREE tiers — no credit card required.

# ── Electricity Maps (Carbon Intensity) ──────────────────────────────────────
# Free tier: 10 calls/month per zone (we cache aggressively)
# Register: https://api.electricitymap.org/free-tier
ELECTRICITY_MAPS_TOKEN=your_token_here

# ── WAQI (Air Quality) ───────────────────────────────────────────────────────
# Free: unlimited personal use
# Register: https://aqicn.org/data-platform/token/
WAQI_TOKEN=demo   # "demo" works for testing

# ── GNews (AI Hype Signal) ───────────────────────────────────────────────────
# Free tier: 100 requests/day
# Register: https://gnews.io
GNEWS_KEY=your_key_here

# ── Optional Enhancements ─────────────────────────────────────────────────────
# NASA POWER API (solar/wind data) — completely free, no key needed
# OpenAQ API — completely free, no key needed
# Cloudflare Radar — completely free, no key needed
# pytrends (Google Trends) — no key needed

# ── CORS & Server Config ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
